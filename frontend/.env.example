# Optional: when all Cognito variables below are set, the UI requires sign-in via
# Amazon Cognito (OAuth 2.0 authorization code + PKCE, hosted UI).
# App client must be a public SPA client (no secret). Allowed callback URLs must
# include the redirect URI; allowed sign-out URLs must include the logout URI.

# VITE_COGNITO_REGION=us-east-1
# VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# VITE_COGNITO_DOMAIN=https://your-app.auth.us-east-1.amazoncognito.com
# VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides (defaults use window.location.origin):
# VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback
# VITE_COGNITO_LOGOUT_URI=http://localhost:5173/login
