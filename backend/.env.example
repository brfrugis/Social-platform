OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b
# Text-to-image for Studio — must be an Ollama image-generation model (POST /api/generate).
# Official examples: x/z-image-turbo, x/flux2-klein (see https://ollama.com/blog/image-generation).
# Qwen-Image-2512 is Hugging Face / diffusers, not pulled as a standard Ollama tag — see docs/IMAGE_GENERATION.md
OLLAMA_IMAGE_MODEL=x/z-image-turbo
PRESETS_PATH=../data/presets.json
TEMPLATES_PATH=../data/templates.json
REQUEST_TIMEOUT_S=600

# Production: comma-separated browser origins allowed to call the API (CORS).
# CORS_ORIGINS=https://app.yourdomain.com

# Optional — OpenTelemetry OTLP (e.g. Coralogix traces). When unset, tracing is off.
# OTEL_SERVICE_NAME=gigi-api
# OTEL_EXPORTER_OTLP_ENDPOINT=https://...
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer YOUR_PRIVATE_KEY

# Optional — cloud text models (Settings UI lets you pick provider + model id)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
#
# For local testing without .env, the Settings page can store keys in the browser; the UI sends them per request as:
#   X-Gigi-OpenAI-Key, X-Gigi-Anthropic-Key, X-Gigi-Google-Key
# (header overrides take precedence over the variables above when present)

# Phase 4 — PostgreSQL (see docker-compose.yml and docs/LOCAL_POSTGRES.md)
# Defaults match docker-compose (gigi/gigi @ localhost:5432). Uncomment and leave empty to disable tenant API:
# DATABASE_URL=
# DATABASE_URL=postgresql+asyncpg://gigi:gigi@127.0.0.1:5432/gigi
